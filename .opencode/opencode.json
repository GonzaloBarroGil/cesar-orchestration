{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["CONSTITUTION.md"],
  "permission": {
    "bash": {
      "git status": "allow",
      "git log *": "allow",
      "git diff *": "allow",
      "git show *": "allow",
      "git commit *": "deny",
      "git reset *": "deny",
      "git revert *": "deny",
      "git rebase *": "deny",
      "git cherry-pick *": "deny",
      "git merge *": "deny",
      "git push *": "deny",
      "git fetch *": "deny",
      "git pull *": "deny",
      "git remote *": "deny",
      "git branch *": "deny",
      "git tag *": "deny",
      "git *": "allow",
      "*": "ask"
    },
    "edit": "allow",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "task": "allow",
    "webfetch": "allow",
    "todowrite": "allow",
    "question": "allow"
  }
}
